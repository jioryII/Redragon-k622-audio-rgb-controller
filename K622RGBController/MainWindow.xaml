<Window x:Class="K622RGBController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Loc[AppTitle]}"
        Width="1080" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        Background="{StaticResource BgMainBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgHeaderBrush}">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⌨" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource AccentGreenBrush}"/>
                    <TextBlock Text="{Binding Loc[AppTitle]}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Loc[AppSubtitle]}" FontSize="13" VerticalAlignment="Center" Margin="4,3,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{Binding Loc[LangToggle]}" Command="{Binding ToggleLanguageCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="10,6" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Foreground="{StaticResource AccentGreenBrush}"/>
                    <Button Content="{Binding ToggleButtonText}" Command="{Binding ToggleCommand}"
                            Style="{StaticResource AccentButton}" Padding="20,8" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="1" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Settings Panel ─── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <StackPanel>

                    <!-- TAB CONTROL -->
                    <TabControl x:Name="SettingsTabs">
                        
                        <!-- ═══ TAB: Música ═══ -->
                        <TabItem Header="{Binding Loc[TabMusic]}">
                            <StackPanel Margin="0,12,0,0">
                                
                                <TextBlock Text="{Binding Loc[HeaderMusic]}" Style="{StaticResource HeaderLabel}"/>
                                <TextBlock Text="{Binding Loc[SubMusic]}" Style="{StaticResource SubLabel}"/>

                                <!-- Dirección (Ángulo) -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[FieldDirection]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding Angle, Mode=TwoWay}" Minimum="0" Maximum="360"
                                                    TickFrequency="15" IsSnapToTickEnabled="True"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AngleText}" Style="{StaticResource ValueLabel}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Audio Sliders -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[HeaderAudioAdjust]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>

                                        <!-- Sensibilidad -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldSensitivity]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding Sensitivity, Mode=TwoWay}" 
                                                    Minimum="0.1" Maximum="3.0" SmallChange="0.1" LargeChange="0.5"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SensitivityText}" Style="{StaticResource ValueLabel}"/>
                                        </Grid>

                                        <!-- Suavizado -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldSmoothing]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding Smoothing, Mode=TwoWay}" 
                                                    Minimum="0" Maximum="0.9" SmallChange="0.05"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SmoothingText}" Style="{StaticResource ValueLabel}"/>
                                        </Grid>

                                        <!-- Caída de barras -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldBarDecay]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding BarDecay, Mode=TwoWay}" 
                                                    Minimum="0.1" Maximum="0.95" SmallChange="0.05"
                                                    Foreground="{StaticResource AccentOrangeBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding BarDecayText}" Style="{StaticResource ValueLabel}"
                                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                                        </Grid>

                                        <!-- Fluidez -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldFluidity]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding Fluidity, Mode=TwoWay}" 
                                                    Minimum="0" Maximum="1" SmallChange="0.05"
                                                    Foreground="{StaticResource AccentOrangeBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding FluidityText}" Style="{StaticResource ValueLabel}"
                                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Colores del Visualizador -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[HeaderSpectrumColors]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                                        <UniformGrid Columns="4" Margin="0,4,0,4" HorizontalAlignment="Stretch">
                                            <Button Command="{Binding EditGradientColorCommand}" CommandParameter="0" 
                                                    Background="{Binding GradientBrushes[0]}" Height="32" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditGradientColorCommand}" CommandParameter="1" 
                                                    Background="{Binding GradientBrushes[1]}" Height="32" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditGradientColorCommand}" CommandParameter="2" 
                                                    Background="{Binding GradientBrushes[2]}" Height="32" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditGradientColorCommand}" CommandParameter="3" 
                                                    Background="{Binding GradientBrushes[3]}" Height="32" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Modo Reposo (Idle Mode) -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[HeaderIdle]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                                        <CheckBox Content="{Binding Loc[FieldIdleEnable]}" 
                                                  IsChecked="{Binding IdleEnabled}"
                                                  Style="{StaticResource ModernCheckBox}" Margin="0,0,0,12"/>
                                                  
                                        <Grid Margin="0,0,0,8" IsEnabled="{Binding IdleEnabled}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldIntensity]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding IdleIntensity, Mode=TwoWay}" 
                                                    Minimum="0.1" Maximum="1.0" SmallChange="0.1"/>
                                            <TextBlock Grid.Column="2" Text="{Binding IdleIntensity, StringFormat={}{0:F2}}" Style="{StaticResource ValueLabel}"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,12" IsEnabled="{Binding IdleEnabled}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldSpeed]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding IdleSpeed, Mode=TwoWay}" 
                                                    Minimum="0.1" Maximum="2.0" SmallChange="0.1"/>
                                            <TextBlock Grid.Column="2" Text="{Binding IdleSpeed, StringFormat={}{0:F2}}" Style="{StaticResource ValueLabel}"/>
                                        </Grid>

                                        <TextBlock Text="{Binding Loc[HeaderIdleColors]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" IsEnabled="{Binding IdleEnabled}"/>
                                        <UniformGrid Columns="4" Margin="0,4,0,4" HorizontalAlignment="Stretch" IsEnabled="{Binding IdleEnabled}">
                                            <Button Command="{Binding EditIdleColorCommand}" CommandParameter="0" 
                                                    Background="{Binding IdleBrushes[0]}" Height="24" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditIdleColorCommand}" CommandParameter="1" 
                                                    Background="{Binding IdleBrushes[1]}" Height="24" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditIdleColorCommand}" CommandParameter="2" 
                                                    Background="{Binding IdleBrushes[2]}" Height="24" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                            <Button Command="{Binding EditIdleColorCommand}" CommandParameter="3" 
                                                    Background="{Binding IdleBrushes[3]}" Height="24" Margin="4" 
                                                    ToolTip="{Binding Loc[EditColor]}" BorderBrush="#33ffffff" BorderThickness="1"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Level Meters -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[HeaderRealTimeLevels]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                                        
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Bass" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding BassLevel}" Style="{StaticResource MeterBar}"
                                                         Foreground="#00ff41"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Mids" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding MidsLevel}" Style="{StaticResource MeterBar}"
                                                         Foreground="#ffdd00"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Treble" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding TrebleLevel}" Style="{StaticResource MeterBar}"
                                                         Foreground="#ff003c"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </TabItem>

                        <!-- ═══ TAB: Notificaciones ═══ -->
                        <TabItem Header="{Binding Loc[TabNotif]}">
                            <StackPanel Margin="0,12,0,0">
                                
                                <TextBlock Text="{Binding Loc[HeaderNotif]}" Style="{StaticResource HeaderLabel}"/>
                                <TextBlock Text="{Binding Loc[SubNotif]}" Style="{StaticResource SubLabel}"/>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <CheckBox Content="{Binding Loc[FieldNotifEnable]}" 
                                                  IsChecked="{Binding NotifEnabled}"
                                                  Style="{StaticResource ModernCheckBox}" Margin="0,0,0,12"/>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldDuration]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding NotifDuration, Mode=TwoWay}"
                                                    Minimum="1" Maximum="10" SmallChange="0.5"
                                                    Foreground="{StaticResource AccentOrangeBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NotifDurationText}" Style="{StaticResource ValueLabel}"
                                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Loc[FieldIntensity]}" Style="{StaticResource FieldLabel}"/>
                                            <Slider Grid.Column="1" Value="{Binding NotifIntensity, Mode=TwoWay}"
                                                    Minimum="0.1" Maximum="1" SmallChange="0.05"
                                                    Foreground="{StaticResource AccentOrangeBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NotifIntensityText}" Style="{StaticResource ValueLabel}"
                                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                                        </Grid>

                                        <Button Content="{Binding Loc[BtnTestNotif]}" Command="{Binding TestNotifCommand}"
                                                Style="{StaticResource ModernButton}" Padding="12,8"
                                                Foreground="{StaticResource AccentOrangeBrush}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               Text="{Binding Loc[NotifDesc]}"/>
                                </Border>
                            </StackPanel>
                        </TabItem>

                        <!-- ═══ TAB: Ajustes ═══ -->
                        <TabItem Header="{Binding Loc[TabSettings]}">
                            <StackPanel Margin="0,12,0,0">
                                
                                <TextBlock Text="{Binding Loc[HeaderGeneral]}" Style="{StaticResource HeaderLabel}"/>
                                <TextBlock Text="{Binding Loc[SubGeneral]}" Style="{StaticResource SubLabel}"/>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <CheckBox Content="{Binding Loc[FieldStartup]}"
                                                  IsChecked="{Binding StartWithWindows}"
                                                  Style="{StaticResource ModernCheckBox}" Margin="0,0,0,12"/>

                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                                   Text="{Binding Loc[StartupDesc]}"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[FieldDevice]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding DeviceName}" Foreground="{StaticResource AccentGreenBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[HeaderAbout]}" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                        <TextBlock Text="K622 RGB Controller v2.0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="Redragon Horus TKL K622" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="Sinowealth HID Protocol" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ─── RIGHT: Keyboard Preview ─── -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Loc[PreviewTitle]}" Style="{StaticResource FieldLabel}" 
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Canvas x:Name="KeyboardCanvas" Grid.Row="1" ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════ FOOTER ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgHeaderBrush}">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Loc[FieldBrightness]}" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <Slider Value="{Binding Brightness, Mode=TwoWay}" Minimum="0" Maximum="1"
                            Width="140" VerticalAlignment="Center" SmallChange="0.05"/>
                    <TextBlock Text="{Binding BrightnessText}" Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>

                <TextBlock Text="{Binding FpsText}" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
